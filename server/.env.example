# server/.env — copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────
PORT=
NODE_ENV=

# ── Database ──────────────────────────────────────────────────
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=

# ── Email (Gmail SMTP) ────────────────────────────────────────
# How to get EMAIL_PASS (Gmail App Password):
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Search "App passwords" → Generate one for "Mail"
#   4. Paste the 16-character code below (no spaces)
EMAIL_USER=
EMAIL_PASS=

# ── Semaphore SMS API ─────────────────────────────────────────
# Get this from your Semaphore dashboard
SMS_PROVIDER=
SEMAPHORE_API_KEY=
# Sender Name (must be approved by Semaphore)
# SEMAPHORE_SENDER_NAME=CARAITMED

# ── Client URL (for email links + CORS) ──────────────────────
CLIENT_URL=
